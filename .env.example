PORT=4000
NODE_ENV=development

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pra_connector_db?schema=public"

JWT_SECRET="replace-with-a-secure-random-secret"
JWT_EXPIRES_IN="7d"

SUPER_ADMIN_EMAIL="admin@praconnector.com"
SUPER_ADMIN_PASSWORD="change-me"
DEMO_CUSTOMER_EMAIL="demo@fenzi.com"
DEMO_CUSTOMER_PASSWORD="change-me"

FRONTEND_URL="https://pra-connector-frontend.vercel.app"

QBO_CLIENT_ID="replace-with-intuit-development-client-id"
QBO_CLIENT_SECRET="replace-with-intuit-development-client-secret"
QBO_REDIRECT_URI="https://pra-connector-backend.onrender.com/api/qbo/callback"
# Development keys → sandbox | Production keys → production
QBO_ENVIRONMENT="sandbox"

PRA_SANDBOX_URL="https://ims.pral.com.pk/ims/sandbox/api/Live/PostData"
PRA_SANDBOX_TOKEN="replace-with-pra-sandbox-token"
